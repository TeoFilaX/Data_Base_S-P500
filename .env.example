# === BASE DE DATOS POSTGRESQL ===
DB_HOST = DB_HOST_HERE
DB_PORT = DB_PORT_HERE
DB_NAME = DB_NAME_HERE
DB_USER = USERNAME_HERE
DB_PASSWORD = DB_PASSWORD_HERE

# === CONFIGURACIÓN DE APLICACIÓN ===
ENVIRONMENT=development
DEBUG=True

# === PIPELINE ETL - S&P 500 ===

# S&P 500
SP500_INDEX=^GSPC
NUM_COMPANIES=500

PRICE_UPDATE_FREQUENCY=weekly
FINANCIAL_FREQUENCY=quarterly
MACRO_FREQUENCY=monthly

# Datos históricos
HISTORICAL_YEARS=10
START_YEAR=2016

# === VARIABLES MACROECONOMICAS ===
MACRO_VARIABLES=CPI,GDP,UNEMPLOYMENT,FED_RATE,YIELD_CURVE_10Y

# Fuentes de datos
YFINANCE_TIMEOUT=30
FRED_API_KEY=YOUR_API_KEY_HERE